<% content_for :title, "Asset library – ForgeAI" %>

<div class="card">
  <h1>Asset library</h1>

  <%= form_with url: assets_path, method: :get, local: true, class: "search-form", role: "search", "aria-label" => "Search assets" do |f| %>
    <%= f.text_field :q, value: @search_query, placeholder: "Search prompts, metadata…", "aria-label" => "Search query", class: "search-input" %>
    <%= f.submit "Search", name: nil, class: "search-submit" %>
  <% end %>

  <% if @search_unavailable && @search_query.present? %>
    <p class="search-unavailable" role="status">Search is not configured; showing all assets.</p>
  <% end %>

  <% if @assets.any? %>
    <ul class="asset-grid">
      <% @assets.each do |asset| %>
        <li class="asset-card">
          <%= link_to asset_path(asset) do %>
            <% if asset.thumbnail.attached? %>
              <%= image_tag asset.thumbnail, alt: asset.filename.presence || "Asset ##{asset.id}", class: "asset-card-thumb", loading: "lazy" %>
            <% else %>
              <span class="asset-card-placeholder" aria-hidden="true">No preview</span>
            <% end %>
            <strong><%= asset.filename.presence || "Asset ##{asset.id}" %></strong>
            <br>
            <time datetime="<%= asset.created_at.iso8601 %>"><%= asset.created_at.strftime("%Y-%m-%d %H:%M") %></time>
          <% end %>
        </li>
      <% end %>
    </ul>
  <% else %>
    <% if @search_query.present? %>
      <p role="status">No assets match your search.</p>
    <% else %>
      <p>No assets yet. Generation jobs do not create assets until the pipeline is connected.</p>
    <% end %>
  <% end %>
</div>
