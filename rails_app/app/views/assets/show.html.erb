<% content_for :title, "Asset ##{@asset.id} – ForgeAI" %>

<div class="card">
  <h1><%= @asset.filename.presence || "Asset ##{@asset.id}" %></h1>

  <% if @asset.file.attached? %>
    <p>
      <%= image_tag @asset.file, alt: @asset.filename.presence || "Asset ##{@asset.id}", class: "asset-show-image" %>
    </p>
  <% end %>
  <% if @asset.thumbnail.attached? %>
    <p>
      <span class="asset-show-thumb-label">Thumbnail:</span>
      <%= image_tag @asset.thumbnail, alt: "Thumbnail for #{@asset.filename.presence || @asset.id}", class: "asset-show-thumb" %>
    </p>
  <% end %>

  <p><strong>Created:</strong> <time datetime="<%= @asset.created_at.iso8601 %>"><%= @asset.created_at.strftime("%Y-%m-%d %H:%M") %></time></p>

  <% if @asset.generation_job %>
    <p><strong>Prompt:</strong> <%= @asset.generation_job.prompt %></p>
    <p><strong>Job status:</strong> <%= @asset.generation_job.status %></p>
    <% if @asset.generation_job.completed_at %>
      <p><strong>Completed:</strong> <time datetime="<%= @asset.generation_job.completed_at.iso8601 %>"><%= @asset.generation_job.completed_at.strftime("%Y-%m-%d %H:%M") %></time></p>
    <% end %>
    <% if @asset.generation_job.error_message.present? %>
      <p><strong>Error:</strong> <span role="alert"><%= @asset.generation_job.error_message %></span></p>
    <% end %>
  <% else %>
    <p>No linked generation job.</p>
  <% end %>

  <% if @asset.metadata.present? && @asset.metadata["generator"].present? %>
    <% gen = @asset.metadata["generator"] %>
    <p><strong>Seed:</strong> <%= gen["seed"] %></p>
    <p><strong>Model:</strong> <%= gen["model"] %></p>
  <% end %>

  <p>
    <%= link_to "Download", download_asset_path(@asset), class: "btn" %>
    <%= link_to "Back to library", assets_path %>
  </p>
</div>
